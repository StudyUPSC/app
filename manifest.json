{
  "name": "📚 Study Portal - Lectures G",
  "short_name": "Study Portal",
  "description": "Access study materials, PDFs, and notes online. Get push notifications for new content.",

  "start_url": "/app/",
  "scope": "/app/",

  "display": "standalone",
  "orientation": "portrait-primary",

  "background_color": "#ffffff",
  "theme_color": "#667eea",

  "categories": ["education", "productivity"],

  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],

  "shortcuts": [
    {
      "name": "Login",
      "short_name": "Login",
      "description": "Login to your account",
      "url": "/app/?login=true",
      "icons": [
        {
          "src": "icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Study Materials",
      "short_name": "Materials",
      "description": "View all study materials",
      "url": "/app/?view=materials",
      "icons": [
        {
          "src": "icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],

  "share_target": {
    "action": "/app/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
